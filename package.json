{
  "name": "open-clicky",
  "version": "0.1.0",
  "description": "Open-source Linux desktop voice assistant (Electron)",
  "homepage": "https://github.com/uzairakram6/open-clicky#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/uzairakram6/open-clicky.git"
  },
  "bugs": {
    "url": "https://github.com/uzairakram6/open-clicky/issues"
  },
  "license": "MIT",
  "author": "Open Clicky contributors",
  "keywords": [
    "electron",
    "linux",
    "voice-assistant",
    "desktop-agent",
    "openai"
  ],
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json && vite build && vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && gcc -O2 -o dist/main/cursor_query src/main/cursor_query.c -lX11 && electron-builder --linux AppImage deb",
    "build:app": "npm run clean && tsc -p tsconfig.json && vite build && vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && gcc -O2 -o dist/main/cursor_query src/main/cursor_query.c -lX11",
    "smoke:packaged": "bash scripts/smoke-packaged-renderer.sh",
    "test": "vitest run",
    "test:e2e": "CLICKY_E2E=1 npx playwright test --config=playwright.config.ts",
    "test:contract": "vitest run tests/contract/",
    "test:smoke": "CLICKY_SMOKE=1 npx playwright test --config=playwright.config.ts tests/smoke/"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/imap": "^0.8.43",
    "@types/mailparser": "^3.4.6",
    "imap": "^0.8.17",
    "linkedom": "^0.18.12",
    "mailparser": "^3.9.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.openclicky.app",
    "productName": "Open Clicky",
    "executableName": "open-clicky",
    "artifactName": "open-clicky-${version}.${ext}",
    "files": [
      "dist/main/**/*",
      "dist/preload/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/main/cursor_query",
        "to": "cursor_query"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Open Clicky contributors"
    }
  }
}
